.env
node_modules/
widget/.build/
widget/.swiftpm/
widget/Playground/.build/
widget/Playground/.swiftpm/

# Swift Package Manager build output anywhere (boyband/stage, future packages).
# Hidden ".build" directory + ".swiftpm" cache get regenerated on every
# `swift build` and have no place in git.
**/.build/
**/.swiftpm/
.release/
duck-eval-test.txt
*.wav

# Claude Code local config
.claude/

# Editor config
.vscode/

# WIP firmware (GPL dependency, not ready for public)
firmware/rubber_duck_c3/
.DS_Store

# PlatformIO build artifacts
firmware/**/.pio/

# Python
.venv/
__pycache__/
*.pyc

# Bambu firmware NVS provisioning (contains WiFi pw + API key)
bambu/firmware/provision.local.csv
bambu/firmware/provision.local.bin

# Bambu cloud login state (single-tenant relay; will become a dict keyed
# by duck_id when multi-tenant lands per #31). Contains access_token +
# account email — must never be committed.
bambu/relay/tokens.json

# ESP-IDF build artifacts (apply to any IDF project under firmware/ or bambu/)
**/build/
**/managed_components/
**/sdkconfig
**/sdkconfig.old
**/dependencies.lock

# Boy Band — local secrets, large stems, DAW projects, build artifacts
# (*.wav is already globally ignored on line 9)
boyband/.env.local
boyband/voices.local.json
boyband/duck-map.local.json
boyband/**/*.mp3
boyband/**/*.aif*
boyband/**/*.logicx
boyband/**/*.als
boyband/**/*.rpp*
boyband/stage/.build/
boyband/stage/.swiftpm/
