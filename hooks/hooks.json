{
  "hooks": {
    "BeforeModel": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${extensionPath}/gemini/hooks/on-before-model.sh",
            "name": "Duck Duck Duck: Score prompt",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${extensionPath}/gemini/hooks/on-after-agent.sh",
            "name": "Duck Duck Duck: Score response",
            "timeout": 10000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${extensionPath}/gemini/hooks/on-notification.sh",
            "name": "Duck Duck Duck: Permission alert",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
