{
  "hooks": {
    "BeforeModel": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./plugin-gemini/hooks/on-before-model.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./plugin-gemini/hooks/on-after-agent.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./plugin-gemini/hooks/on-notification.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
